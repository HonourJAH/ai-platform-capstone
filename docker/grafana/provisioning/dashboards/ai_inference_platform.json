{
  "title": "AI Inference Platform",
  "uid": "ai-inference-platform",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Requests per second by task type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(inference_requests_total[1m])) by (task_type)",
          "legendFormat": "{{task_type}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "p95 latency by task type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(inference_request_latency_seconds_bucket[5m])) by (le, task_type))",
          "legendFormat": "{{task_type}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Rate limit rejections per second by tier",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(rate_limit_rejections_total[1m])) by (tier)",
          "legendFormat": "{{tier}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP requests per second by status code",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (status_code)",
          "legendFormat": "{{status_code}}"
        }
      ]
    }
  ]
}
